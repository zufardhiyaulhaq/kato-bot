# kato-bot local configuration — copy to .env and fill in.
#
# kato-bot does NOT auto-load .env. Load it into your shell before running, e.g.:
#   set -a; source .env; set +a
#   go run ./cmd/kato-bot
#
# .env is gitignored; .env.example is the committed template.

# --- Required: Lark app credentials ---
# From the Lark/Feishu Developer Console → your app → Credentials & Basic Info.
# The app needs bot capability, the im:message scopes (send/reply/patch), and event
# subscription over a long connection (WebSocket): im.message.receive_v1 + card actions.
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- kato backend ---
# In-cluster default is http://kato.kato.svc:8080. To run the bot locally against a
# cluster, port-forward kato first:
#   kubectl -n kato port-forward svc/kato 8080:8080
# then point the bot at the forwarded port:
KATO_BASE_URL=http://localhost:8080

# Per-run client timeout (Go duration). kato's POST /run is synchronous and can take
# tens of seconds while it runs the checks and summarizes.
KATO_RUN_TIMEOUT=60s

# --- Optional ---
# Log verbosity for the Lark SDK: debug | info | warn | error (default info).
LOG_LEVEL=info

# Address for the /healthz and /readyz probe server (default :8080). Override locally if
# :8080 collides with your kubectl port-forward above (the bot's health server and the
# forwarded kato port would both want 8080) — e.g. set :8081 when forwarding kato to 8080.
HEALTH_ADDR=:8081

# Max in-flight kato runs before new submits get a "kato is busy" card (default 4).
MAX_CONCURRENT_RUNS=4
